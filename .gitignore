k3c
dist/
# but DO commit the web UI bundle: it is small, content-hashed, and embedded
# into the binary via go:embed, so `go build ./...` works without a node step.
!/web/dist/
!/web/dist/**

# local make overrides (STAGING_DIR, INIT_TAR, ...)
.env

# bundled container runtime payload — large, produced by `make bundle`
runtime/payload/*.tar.gz
runtime/payload/*.tar
runtime/payload/init.tar
runtime/payload/container-version.txt

# fork checkouts + runtime stage: .forks/ (release workflow), tmp/ (make build)
.forks/
/tmp/
*.k3csnap
.DS_Store
ui/.build
